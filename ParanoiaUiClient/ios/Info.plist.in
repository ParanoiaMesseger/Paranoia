<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Paranoia</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>app.paranoia.client</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Paranoia</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>@PROJECT_VERSION@</string>
    <key>CFBundleVersion</key>
    <string>@PARANOIA_APP_VERSION@</string>
    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>NSCameraUsageDescription</key>
    <string>Камера нужна для сканирования QR-кодов обмена ключами и видеозвонков.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Микрофон нужен для голосовых и видеозвонков.</string>
    <key>NSLocalNetworkUsageDescription</key>
    <string>Доступ к локальной сети нужен для P2P-звонков и работы STUN/TURN в той же Wi-Fi-сети.</string>
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Доступ к фотогалерее нужен, чтобы прикреплять изображения к сообщениям.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Доступ к фотогалерее нужен, чтобы сохранять полученные изображения.</string>
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UIBackgroundModes</key>
    <array>
        <string>processing</string>
        <string>voip</string>
        <string>audio</string>
    </array>
    <key>BGTaskSchedulerPermittedIdentifiers</key>
    <array>
        <string>com.paranoia.polling</string>
    </array>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>
    <key>UIRequiredDeviceCapabilities</key>
    <array>
        <string>arm64</string>
    </array>
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>
    <!-- Регистрация в Share-sheet'е и в "Открыть с помощью" в Files.
         Share-extension (см. ios/ShareExtension) кладёт shared payload в App
         Group group.app.paranoia.client и затем открывает основное приложение
         через URL-схему paranoia://share — её разрешает CFBundleURLTypes ниже.
         CFBundleDocumentTypes отвечает за «Открыть в Paranoia» при работе с
         документами и медиа из системных приложений. -->
    <key>CFBundleDocumentTypes</key>
    <array>
        <dict>
            <key>CFBundleTypeName</key>
            <string>Документ</string>
            <key>CFBundleTypeRole</key>
            <string>Viewer</string>
            <key>LSHandlerRank</key>
            <string>Alternate</string>
            <key>LSItemContentTypes</key>
            <array>
                <string>public.item</string>
                <string>public.content</string>
                <string>public.image</string>
                <string>public.movie</string>
                <string>public.audio</string>
                <string>public.text</string>
                <string>public.data</string>
            </array>
        </dict>
    </array>
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>app.paranoia.client</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>paranoia</string>
            </array>
        </dict>
    </array>
    <key>UISupportsDocumentBrowser</key>
    <true/>
</dict>
</plist>
