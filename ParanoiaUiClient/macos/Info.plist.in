<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <!-- Базовый язык — русский; en.lproj/*.strings даёт английский
         (apple/*.lproj + CMake-блок «Нативная локализация Apple»). -->
    <key>CFBundleLocalizations</key>
    <array>
        <string>ru</string>
        <string>en</string>
    </array>
    <key>CFBundleDisplayName</key>
    <string>Paranoia</string>
    <key>CFBundleExecutable</key>
    <string>Paranoia</string>
    <key>CFBundleIdentifier</key>
    <string>app.paranoia.client</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>Paranoia</string>
    <key>CFBundlePackageType</key>
    <string>APPL</string>
    <key>CFBundleShortVersionString</key>
    <string>@PROJECT_VERSION@</string>
    <key>CFBundleVersion</key>
    <string>@PARANOIA_APP_VERSION@</string>
    <key>NSCameraUsageDescription</key>
    <string>Камера нужна для сканирования QR-кодов обмена ключами.</string>
    <key>NSHighResolutionCapable</key>
    <true/>
</dict>
</plist>
