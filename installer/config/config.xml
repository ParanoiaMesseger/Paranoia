<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <Name>Paranoia</Name>
    <!-- CI rewrites this from ParanoiaUiClient/CMakeLists.txt before packaging. -->
    <Version>0.2.1.0</Version>
    <Title>Paranoia Setup</Title>
    <Publisher>Paranoia</Publisher>
    <StartMenuDir>Paranoia</StartMenuDir>
    <!-- User-space install: no admin rights required for main installation -->
    <TargetDir>@HomeDir@/AppData/Local/Programs/Paranoia</TargetDir>
    <MaintenanceToolName>ParanoiaMaintenance</MaintenanceToolName>
    <ControlScript>controlscript.qs</ControlScript>
    <AllowSpaceInPath>true</AllowSpaceInPath>
    <InstallActionColumnVisible>false</InstallActionColumnVisible>
    <RunProgram>@TargetDir@/bin/Paranoia.exe</RunProgram>
    <RunProgramDescription>Launch Paranoia</RunProgramDescription>
    <!-- IFW appends .ico / .icns / .png depending on platform -->
    <InstallerWindowIcon>../../ParanoiaUiClient/resources/design/paranoia</InstallerWindowIcon>
</Installer>
