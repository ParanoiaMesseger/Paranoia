    /// Получить расшифрованные байты вложения в память (plaintext на диск НЕ
    /// пишется). Caller получает владение QByteArray; FFI-буфер освобождается
    /// здесь же через paranoia_free_buffer. Пустой QByteArray = ошибка.
    QByteArray cache_attachment_bytes_keyring(QSTR user_a, QSTR user_b, QSTR keyring_json, QSTR message_id)
    {
        unsigned char *buf = nullptr;
        size_t len = 0;
        const int rc = ::paranoia_cache_attachment_bytes_keyring(
            ptr, QS_RS(user_a), QS_RS(user_b), QS_RS(keyring_json), QS_RS(message_id), &buf, &len);
        if (rc != 0 || !buf || len == 0) {
            if (buf) ::paranoia_free_buffer(buf, len);
            return {};
        }
        QByteArray out(reinterpret_cast<const char *>(buf), static_cast<qsizetype>(len));
        ::paranoia_free_buffer(buf, len);
        return out;
    }

