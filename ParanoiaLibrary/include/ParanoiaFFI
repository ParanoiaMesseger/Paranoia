    static VaultUnlockResult vault_unlock_token(QSTR module_path, QSTR token_pin)
    {
        const int rc = ::paranoia_vault_unlock_token(QS_RS(module_path), QS_RS(token_pin));
        switch (rc) {
            case 0: return VaultUnlockResult::Ok;
            case 3: return VaultUnlockResult::NotInitialized;
            default: return VaultUnlockResult::Internal;
        }
    }

    // ── Masking-профиль ──────────────────────────────────────────────────────
    int set_masking_profile(QSTR profile_json)
    { return ::paranoia_set_masking_profile(ptr, QS_RS(profile_json)); }

    int set_signed_masking_profile(QSTR signed_json, QSTR trusted_pubkey_b64)
    { return ::paranoia_set_signed_masking_profile(ptr, QS_RS2(signed_json, trusted_pubkey_b64)); }

    // Подписать профиль extended-секретом (панель). Пустая строка при ошибке.
    static QString sign_masking_profile(QSTR profile_json, QSTR extended_secret_b64)
    { return RS_QS(::paranoia_sign_masking_profile(QS_RS2(profile_json, extended_secret_b64))); }

    int fetch_and_apply_signed_profile(QSTR url, QSTR trusted_pubkey_b64, QSTR bearer_token)
    { return ::paranoia_fetch_and_apply_signed_profile(ptr, QS_RS3(url, trusted_pubkey_b64, bearer_token)); }

    // Активный masking-профиль для admin/reg-трафика (глобально). "" — очистить.
    static int admin_set_masking_profile(QSTR profile_json)
    { return ::paranoia_admin_set_masking_profile(QS_RS(profile_json)); }

